@@ -24,6 +24,13 @@ produce. The tool wrapper JSON-serializes it. Keys:
     provider       str              provider name (for diagnostics)
     error          str              only when success=False
     error_type     str              only when success=False
+
+Image editing
+-------------
+Providers that support image-to-image / inpainting can override
+``edit(...)``. The base implementation returns an explicit unsupported error
+so the public ``image_edit`` tool can dispatch uniformly without relying on
+``hasattr`` checks or provider-specific type tests.
 """
 
 from __future__ import annotations
@@ -142,6 +149,31 @@ class ImageGenProvider(abc.ABC):
         should ignore unknown keys.
         """
 
+    def edit(
+        self,
+        prompt: str,
+        image_path: str,
+        aspect_ratio: str = DEFAULT_ASPECT_RATIO,
+        mask_path: Optional[str] = None,
+        **kwargs: Any,
+    ) -> Dict[str, Any]:
+        """Edit an input image using a prompt.
+
+        Backends that expose image-to-image / inpainting should override this.
+        ``image_path`` and ``mask_path`` are local filesystem paths or backend-
+        accepted URLs, depending on the provider. The default is a structured
+        error rather than ``NotImplementedError`` so agent-facing tools can
+        return useful diagnostics to the user.
+        """
+        return error_response(
+            error=f"Image editing is not supported by provider '{self.name}'",
+            error_type="unsupported_operation",
+            provider=self.name,
+            model=self.default_model() or self.name,
+            prompt=prompt,
+            aspect_ratio=resolve_aspect_ratio(aspect_ratio),
+        )
+
 
