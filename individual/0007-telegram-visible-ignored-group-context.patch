+
+    def _fetch_recent_channel_context(self, message: Message) -> str:
+        """Recover a minimal same-chat/thread reply chain for context.
+
+        Telegram's bot API does not provide general-purpose backscroll like
+        Discord history(). The safe universally-available primitive is the
+        reply chain already embedded in the incoming update payload. We exploit
+        that without claiming broader history access.
+        """
+        limit = self._telegram_history_backfill_limit()
+        if limit <= 0:
+            return ""
+
+        collected: list[Message] = []
+        seen_ids: set[str] = set()
+        trigger_chat = getattr(message, "chat", None)
+        trigger_chat_id = str(getattr(trigger_chat, "id", ""))
+        trigger_thread_id = getattr(message, "message_thread_id", None)
+        current = getattr(message, "reply_to_message", None)
+
+        while current is not None and len(collected) < limit:
+            current_chat = getattr(current, "chat", None)
+            if str(getattr(current_chat, "id", "")) != trigger_chat_id:
+                break
+            if getattr(current, "message_thread_id", None) != trigger_thread_id:
+                break
+
+            current_id = str(getattr(current, "message_id", ""))
+            if current_id and current_id in seen_ids:
+                break
+            if current_id:
+                seen_ids.add(current_id)
+            collected.append(current)
+            current = getattr(current, "reply_to_message", None)
+
+        if not collected:
+            return ""
+
+        collected.sort(key=self._message_sort_key)
+        lines = [self._format_history_message_for_context(item) for item in collected]
+        lines = [line for line in lines if line]
+        if not lines:
+            return ""
+        return "[Recent replied context]\n" + "\n".join(lines)
+
+    def _build_channel_context_for_trigger(self, message: Message) -> str:
+        blocks = []
+        cached = self._fetch_cached_channel_context(message)
+        if cached:
+            blocks.append(cached)
+        replied = self._fetch_recent_channel_context(message)
+        if replied:
+            blocks.append(replied)
+        return "\n\n".join(blocks)
