+            elif getattr(message, "audio", None):
+                text = "(audio)"
+            elif getattr(message, "voice", None):
+                text = "(voice)"
+            elif getattr(message, "sticker", None):
+                text = "(sticker)"
+        if not text:
+            return None
+
+        from_user = getattr(message, "from_user", None)
+        sender = (
+            getattr(from_user, "full_name", None)
+            or getattr(from_user, "username", None)
+            or getattr(getattr(message, "sender_chat", None), "title", None)
+            or "Unknown"
+        )
+        if from_user is not None and getattr(from_user, "is_bot", False):
+            sender = f"{sender} [bot]"
