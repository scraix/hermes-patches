+    def _cache_group_context_message(self, message: Message) -> None:
+        """Keep a bounded in-memory context window for visible group messages.
+
+        This records only updates Telegram already delivered to the bot. With
+        BotFather privacy mode enabled, ordinary non-command/non-mention group
+        messages are never delivered, so they cannot be cached here.
+        """
+        if not self._is_group_chat(message):
+            return
+        limit = self._telegram_context_cache_limit()
+        if limit <= 0:
+            return
+        if not self._format_history_message_for_context(message):
+            return
+        key = self._telegram_context_cache_key(message)
+        cache = self._recent_group_context.get(key)
+        if cache is None or cache.maxlen != limit:
+            cache = deque(cache or [], maxlen=limit)
+            self._recent_group_context[key] = cache
+        message_id = str(getattr(message, "message_id", ""))
+        if message_id and any(str(getattr(item, "message_id", "")) == message_id for item in cache):
+            return
+        cache.append(message)
+
+    def _fetch_cached_channel_context(self, message: Message) -> str:
+        limit = self._telegram_history_backfill_limit()
+        if limit <= 0:
+            return ""
+        cache = self._recent_group_context.get(self._telegram_context_cache_key(message))
+        if not cache:
+            return ""
+        trigger_id = str(getattr(message, "message_id", ""))
+        candidates = [item for item in cache if str(getattr(item, "message_id", "")) != trigger_id]
+        if not candidates:
+            return ""
+        candidates = candidates[-limit:]
+        lines = [self._format_history_message_for_context(item) for item in candidates]
+        lines = [line for line in lines if line]
+        if not lines:
+            return ""
+        return "[Recent visible group messages]\n" + "\n".join(lines)
