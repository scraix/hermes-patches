+def _custom_provider_entry(provider: str, base_url: str = "", custom_providers: list | None = None) -> Optional[dict]:
+    """Return the config entry for a custom provider slug/name/base_url."""
+    if not custom_providers or not isinstance(custom_providers, list):
+        return None
+    wanted = str(provider or "").strip().lower()
+    wanted_url = str(base_url or "").strip().rstrip("/").lower()
+    for entry in custom_providers:
+        if not isinstance(entry, dict):
+            continue
+        name = str(entry.get("name") or "").strip()
+        slug = custom_provider_slug(name).lower() if name else ""
+        url = str(entry.get("base_url") or entry.get("url") or entry.get("api") or "").strip().rstrip("/").lower()
+        if wanted and wanted in {name.lower(), slug}:
+            return entry
+        if wanted_url and url and wanted_url == url:
+            return entry
+    return None
+
+
+def _custom_provider_default_model(provider: str, base_url: str = "", custom_providers: list | None = None) -> str:
+    """Return the configured default model for a custom provider, if any."""
+    entry = _custom_provider_entry(provider, base_url, custom_providers)
+    if not entry:
+        return ""
+    for key in ("model", "default_model", "default"):
+        value = str(entry.get(key) or "").strip()
+        if value:
+            return value
+    models = entry.get("models")
+    if isinstance(models, dict):
+        for mid in models:
+            if mid:
+                return str(mid)
+    if isinstance(models, list):
+        for item in models:
+            if isinstance(item, str) and item.strip():
+                return item.strip()
+            if isinstance(item, dict):
+                val = str(item.get("name") or item.get("id") or "").strip()
+                if val:
+                    return val
+    return ""
+
